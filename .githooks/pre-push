#!/bin/sh
# pre-push: github.io の push 対象コミット範囲の秘密/PII を repo_audit.py で監査する一次防御。
# git が stdin に "<local ref> <local sha> <remote ref> <remote sha>" を渡す。--no-verify で回避可。
root=$(git rev-parse --show-toplevel) || exit 0
audit="$root/../scripts/repo_audit.py"
[ -f "$audit" ] || exit 0

zero=$(git hash-object --stdin </dev/null | tr '0-9a-f' '0')
status=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$zero" ] && continue
  if [ "$remote_sha" = "$zero" ]; then
    base=$(git merge-base "$local_sha" origin/main 2>/dev/null)
    if [ -n "$base" ]; then range="$base..$local_sha"; else range="$local_sha~20..$local_sha"; fi
  else
    range="$remote_sha..$local_sha"
  fi
  python3 "$audit" --range "$range" 2>/dev/null || python3 "$audit" --range "$local_sha"
  [ "$?" -eq 1 ] && status=1
done

if [ "$status" -eq 1 ]; then
  echo ""
  echo "🛑 push 中止：秘密または個人情報の疑い（上記 file:line）。"
  echo "   履歴から除去するか、誤検知が確実なら 'git push --no-verify'（自己責任）。"
  exit 1
fi
exit 0
